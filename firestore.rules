rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Contact form: anonymous visitors may only CREATE well-formed messages.
    // Reading, updating and deleting is admin-only (Admin SDK bypasses rules).
    match /mails/{mailId} {
      allow create: if
        request.resource.data.keys().hasOnly(['name', 'email', 'location', 'message']) &&
        request.resource.data.keys().hasAll(['name', 'email', 'location', 'message']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() <= 200 &&
        request.resource.data.email is string &&
        request.resource.data.email.size() <= 320 &&
        request.resource.data.email.matches('.+@.+\\..+') &&
        request.resource.data.location is string &&
        request.resource.data.location.size() <= 200 &&
        request.resource.data.message is string &&
        request.resource.data.message.size() > 0 &&
        request.resource.data.message.size() <= 5000;
      allow read, update, delete: if false;
    }

    // Everything else: locked down.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
