{
  "private": true,
  "scripts": {
    "build:frontend": "tsc && node scripts/write-firebase-web-config.cjs",
    "watch:frontend": "tsc --watch",
    "build:css": "sass public/css/style.scss public/css/style.css && sass --style=compressed public/css/style.scss public/css/style.min.css",
    "watch:css": "sass --watch public/css/style.scss:public/css/style.css",
    "serve": "npx --yes serve public",
    "dev": "node scripts/write-firebase-web-config.cjs && concurrently -k -n TS,CSS,WEB \"npm:watch:frontend\" \"npm:watch:css\" \"npm:serve\"",
    "build:inject-assets": "node scripts/inject-asset-version.cjs",
    "build": "npm run build:frontend && npm run build:css && npm run build:inject-assets",
    "typecheck": "tsc --noEmit",
    "verify:functions": "node -e \"require('child_process').execSync('npm run lint && npm run build',{stdio:'inherit',cwd:require('path').resolve(process.cwd(),'functions')})\"",
    "verify": "npm run typecheck && npm run build:css && npm run verify:functions"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "sass": "^1.93.2",
    "typescript": "^5.9.3"
  }
}
